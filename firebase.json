{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "ai-local/**"
    ],
    "rewrites": [
      {
        "source": "/api{,/**}",
        "function": {
          "functionId": "aiApi",
          "region": "europe-west1"
        }
      }
    ]
  }
}
